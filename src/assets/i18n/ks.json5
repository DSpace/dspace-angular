  "comcol-role.edit.community-admin.name": "Administrator",

  "comcol-role.edit.collection-admin.name": "Administrator",

  "comcol-role.edit.community-admin.description": "Community administrator ہیکن ذیلی community یا collection بنٲوِتھ، تہٕ تِہنٛد انتظام سنبھٲلِتھ یا مقرر کٔرِتھ۔ اَسہِ علاوہ، تِم فیصلہ کٔران زِ کٔس ہیکِ کٕنہِ تہِ ذیلی collection منٛز آئٹم جمع کٔرِتھ، آئٹم metadata اَیڈِٹ کٔرِتھ (جمع کٔرنس پتہٕ)، تہٕ بیٚیہِ collection ن پٮ۪ٹھ موجود آئٹم شامِل (map) کٔرِتھ (authorization ہُنٛد پابند روزِتھ)।",

  "comcol-role.edit.collection-admin.description": "Collection administrator فیصلہ کٔران زِ کٔس ہیکِ collection منٛز آئٹم جمع کٔرِتھ، آئٹم metadata اَیڈِٹ کٔرِتھ (جمع کٔرنس پتہٕ)، تہٕ بیٚیہِ collection ن پٮ۪ٹھ موجود آئٹم یِتھ collection منٛز شامِل (map) کٔرِتھ (تَتھ collection ہِنٛد authorization ہُنٛد پابند روزِتھ)।",

  "comcol-role.edit.submitters.name": "جمع کٔرن والہٕ",

  "comcol-role.edit.submitters.description": "سُہ E-People تہٕ Group یِم یَتھ collection منٛز نو بیٚیہِ آئٹم جمع کٔرنس خٲطرٕ اِجازت چھِ۔",

  "comcol-role.edit.item_read.name": "پہلے پٮ۪ٹھ item read رسٲی",

  "comcol-role.edit.item_read.description": "سُہ E-People تہٕ Group یِم یَتھ collection منٛز جمع کرنہٕ آمٕت نو بیٚیہِ آئٹم پٔرِتھ ہیکن۔ یِم کردارَس منٛز تبدیلیو پَتِم اَثر نَہ کرنہٕ گژھن۔ سسٹم منٛز موجود آئٹم وۄنۍ تہِ تِمہِ لوکن ہیکن وُچھِتھ یِمن تِہنٛد شامِل گژھنہٕ وۄقت read رسٲی آسہٕ۔",

  "comcol-role.edit.item_read.anonymous-group": "اَنٕنہٕ آمٕت آئٹمن خٲطرٕ پہلے پٮ۪ٹھ read وۄنۍ Anonymous پٮ۪ٹھ مقرر چھُ۔",

  "comcol-role.edit.bitstream_read.name": "پہلے پٮ۪ٹھ bitstream read رسٲی",

