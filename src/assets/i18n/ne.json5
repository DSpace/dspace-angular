  "external-login.component.or": "वा",
  "external-login.confirmation.header": "लगइन प्रक्रिया पूरा गर्न आवश्यक जानकारी",
  "external-login.noEmail.informationText": "{{authMethod}} बाट प्राप्त जानकारी लगइन प्रक्रिया पूरा गर्न पर्याप्त छैन। कृपया तल हराइरहेको जानकारी प्रदान गर्नुहोस्, वा आफ्नो {{authMethod}} लाई अवस्थित खातासँग आबद्ध गर्न फरक विधिबाट लगइन गर्नुहोस्।",
  "external-login.haveEmail.informationText": "यस्तो देखिन्छ कि तपाईंको यस प्रणालीमा अझै खाता छैन। यदि त्यस्तो हो भने, कृपया {{authMethod}} बाट प्राप्त डेटा पुष्टि गर्नुहोस् र तपाईंका लागि नयाँ खाता सिर्जना गरिनेछ। अन्यथा, यदि तपाईंको यस प्रणालीमा पहिले नै खाता छ भने, कृपया यहाँको ईमेल ठेगानालाई प्रणालीमा पहिले देखि प्रयोग भइरहेको ईमेलसँग मिलाउनुहोस् वा आफ्नो {{authMethod}} लाई अवस्थित खातासँग आबद्ध गर्न फरक विधिबाट लगइन गर्नुहोस्।",

  "external-login.confirm-email.header": "ईमेल पुष्टि गर्नुहोस् वा अद्यावधिक गर्नुहोस्",
  "external-login.confirmation.email-required": "ईमेल आवश्यक छ।",
  "external-login.confirmation.email-label": "प्रयोगकर्ता ईमेल",
