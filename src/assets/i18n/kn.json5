  "admin.notifications.publicationclaim.page.title": "ಪ್ರಕಟಣೆ ಹಕ್ಕು",

  "coar-notify-support.title": "COAR ನೋಟಿಫೈ ಪ್ರೋಟೋಕಾಲ್",

  "coar-notify-support-title.content": "ಇಲ್ಲಿ, ನಾವು ರೆಪೊಸಿಟರಿಗಳ ನಡುವಿನ ಸಂವಹನವನ್ನು ಹೆಚ್ಚಿಸಲು ವಿನ್ಯಾಸಗೊಳಿಸಲಾದ COAR ನೋಟಿಫೈ ಪ್ರೋಟೋಕಾಲ್ ಅನ್ನು ಸಂಪೂರ್ಣವಾಗಿ ಬೆಂಬಲಿಸುತ್ತೇವೆ. COAR ನೋಟಿಫೈ ಪ್ರೋಟೋಕಾಲ್ ಬಗ್ಗೆ ಇನ್ನಷ್ಟು ತಿಳಿಯಲು, <a href=\"https://notify.coar-repositories.org/\" rel=\"noopener noreferrer\">COAR ನೋಟಿಫೈ ವೆಬ್‌ಸೈಟ್</a> ಭೇಟಿ ನೀಡಿ.",

  "coar-notify-support.ldn-inbox.title": "LDN ಇನ್‌ಬಾಕ್ಸ್",

  "coar-notify-support.ldn-inbox.content": "ನಿಮ್ಮ ಅನುಕೂಲಕ್ಕಾಗಿ, ನಮ್ಮ LDN (ಲಿಂಕ್ಡ್ ಡೇಟಾ ನೋಟಿಫಿಕೇಶನ್ಸ್) ಇನ್‌ಬಾಕ್ಸ್ {{ ldnInboxUrl }} ನಲ್ಲಿ ಸುಲಭವಾಗಿ ಪ್ರವೇಶಿಸಬಹುದು. LDN ಇನ್‌ಬಾಕ್ಸ್ ತಡೆರಹಿತ ಸಂವಹನ ಮತ್ತು ಡೇಟಾ ವಿನಿಮಯವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸುತ್ತದೆ, ಸಮರ್ಥ ಮತ್ತು ಪರಿಣಾಮಕಾರಿ ಸಹಯೋಗವನ್ನು ಖಚಿತಪಡಿಸುತ್ತದೆ.",

  "coar-notify-support.message-moderation.title": "ಸಂದೇಶ ಮಧ್ಯಸ್ಥಿಕೆ",

  "coar-notify-support.message-moderation.content": "ಸುರಕ್ಷಿತ ಮತ್ತು ಫಲಪ್ರದ ಪರಿಸರ ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಲು, ಬರುವ ಎಲ್ಲ LDN ಸಂದೇಶಗಳನ್ನು ಮಧ್ಯಸ್ಥಿಕೆ ಮಾಡಲಾಗುತ್ತದೆ. ನಮ್ಮೊಂದಿಗೆ ಮಾಹಿತಿ ವಿನಿಮಯ ಯೋಜಿಸುತ್ತಿದ್ದರೆ, ದಯವಿಟ್ಟು ನಮ್ಮ ಮೀಸಲಾದ",

  "coar-notify-support.message-moderation.feedback-form": " ಪ್ರತಿಕ್ರಿಯೆ ಫಾರ್ಮ್.",

