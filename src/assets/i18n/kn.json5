  "comcol-role.edit.no-group": "ಯಾವುದೂ ಇಲ್ಲ",

  "comcol-role.edit.create": "ರಚಿಸಿ",

  "comcol-role.edit.create.error.title": "'{{ role }}' ಪಾತ್ರಕ್ಕಾಗಿ ಗುಂಪು ರಚಿಸಲು ವಿಫಲವಾಯಿತು",

