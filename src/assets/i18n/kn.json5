  "comcol-role.edit.delete.error.title": "'{{ role }}' ಪಾತ್ರದ ಗುಂಪನ್ನು ಅಳಿಸಲು ವಿಫಲವಾಯಿತು",

  "comcol-role.edit.delete.modal.header": "ಗುಂಪು \"{{ dsoName }}\" ಅನ್ನು ಅಳಿಸಿ",

  "comcol-role.edit.delete.modal.info": "ಗುಂಪು \"{{ dsoName }}\" ಮತ್ತು ಅದರ ಸಂಬಂಧಿತ ಎಲ್ಲಾ ನೀತಿಗಳನ್ನು ನಿಜವಾಗಿಯೂ ಅಳಿಸಲು ಬಯಸುವಿರಾ?",

  "comcol-role.edit.delete.modal.cancel": "ರದ್ದುಮಾಡಿ",

  "comcol-role.edit.delete.modal.confirm": "ಅಳಿಸಿ",

  "comcol-role.edit.community-admin.name": "ನಿರ್ವಾಹಕರು",

  "comcol-role.edit.collection-admin.name": "ನಿರ್ವಾಹಕರು",

  "comcol-role.edit.community-admin.description": "ಸಮುದಾಯ ನಿರ್ವಾಹಕರು ಉಪಸಮುದಾಯಗಳು ಅಥವಾ ಸಂಕಲನಗಳನ್ನು ರಚಿಸಬಹುದು, ಮತ್ತು ಆ ಉಪಸಮುದಾಯಗಳು ಅಥವಾ ಸಂಕಲನಗಳ ನಿರ್ವಹಣೆಯನ್ನು ನಿರ್ವಹಿಸಬಹುದು ಅಥವಾ ನಿಯೋಜಿಸಬಹುದು. ಜೊತೆಗೆ, ಯಾವವರು ಯಾವುದೇ ಉಪಸಂಕಲನಗಳಿಗೆ ಐಟಂಗಳನ್ನು ಸಲ್ಲಿಸಬಹುದು, ಐಟಂ ಮೆಟಾಡೇಟಾವನ್ನು (ಸಲ್ಲಿಕೆಯ ನಂತರ) ಸಂಪಾದಿಸಬಹುದು, ಮತ್ತು ಇತರ ಸಂಕಲನಗಳಿಂದ ಇರುವ ಐಟಂಗಳನ್ನು ಸೇರಿಸಬಹುದು (ಮ್ಯಾಪ್ ಮಾಡಬಹುದು) ಎಂಬುದನ್ನೂ ಅವರು ನಿರ್ಧರಿಸುತ್ತಾರೆ (ಅಧಿಕೃತತೆಯ ಅಧೀನದಲ್ಲಿ).",

  "comcol-role.edit.collection-admin.description": "ಸಂಕಲನ ನಿರ್ವಾಹಕರು ಸಂಕಲನಕ್ಕೆ ಯಾವವರು ಐಟಂಗಳನ್ನು ಸಲ್ಲಿಸಬಹುದು, ಐಟಂ ಮೆಟಾಡೇಟಾವನ್ನು (ಸಲ್ಲಿಕೆಯ ನಂತರ) ಸಂಪಾದಿಸಬಹುದು, ಮತ್ತು ಇತರ ಸಂಕಲನಗಳಿಂದ ಇರುವ ಐಟಂಗಳನ್ನು ಈ ಸಂಕಲನಕ್ಕೆ ಸೇರಿಸಬಹುದು (ಮ್ಯಾಪ್ ಮಾಡಬಹುದು) ಎಂಬುದನ್ನೂ ನಿರ್ಧರಿಸುತ್ತಾರೆ (ಆ ಸಂಕಲನದ ಅಧಿಕೃತತೆಯ ಅಧೀನದಲ್ಲಿ).",

  "comcol-role.edit.submitters.name": "ಸಲ್ಲಿಸುವವರು",

  "comcol-role.edit.submitters.description": "ಈ ಸಂಕಲನಕ್ಕೆ ಹೊಸ ಐಟಂಗಳನ್ನು ಸಲ್ಲಿಸಲು ಅನುಮತಿ ಇರುವ E-People ಮತ್ತು ಗುಂಪುಗಳು.",

  "comcol-role.edit.item_read.name": "ಪೂರ್ವನಿಯೋಜಿತ ಐಟಂ ಓದುವ ಪ್ರವೇಶ",

  "comcol-role.edit.item_read.description": "ಈ ಸಂಕಲನಕ್ಕೆ ಸಲ್ಲಿಸಲಾದ ಹೊಸ ಐಟಂಗಳನ್ನು ಓದಲು ಸಾಧ್ಯವಿರುವ E-People ಮತ್ತು ಗುಂಪುಗಳು. ಈ ಪಾತ್ರಕ್ಕೆ ಮಾಡುವ ಬದಲಾವಣೆಗಳು ಹಿಂದಿನ ದಿನಾಂಕದಿಂದ ಅನ್ವಯಿಸುವುದಿಲ್ಲ. ವ್ಯವಸ್ಥೆಯಲ್ಲಿರುವ ಹಳೆಯ ಐಟಂಗಳು ಅವುಗಳನ್ನು ಸೇರಿಸಿದ ಸಮಯದಲ್ಲಿ ಓದುವ ಪ್ರವೇಶ ಇದ್ದವರಿಂದ ಇನ್ನೂ ವೀಕ್ಷಿಸಬಹುದು.",

  "comcol-role.edit.item_read.anonymous-group": "ಬರುವ ಐಟಂಗಳಿಗಾಗಿ ಪೂರ್ವನಿಯೋಜಿತ ಓದು ಪ್ರಸ್ತುತ Anonymous ಗೆ ಹೊಂದಿಸಲಾಗಿದೆ.",

  "comcol-role.edit.bitstream_read.name": "ಪೂರ್ವನಿಯೋಜಿತ ಬಿಟ್‌ಸ್ಟ್ರೀಮ್ ಓದುವ ಪ್ರವೇಶ",

  "comcol-role.edit.bitstream_read.description": "ಈ ಸಂಕಲನಕ್ಕೆ ಸಲ್ಲಿಸಲಾದ ಹೊಸ ಬಿಟ್‌ಸ್ಟ್ರೀಮ್‌ಗಳನ್ನು ಓದಲು ಸಾಧ್ಯವಿರುವ E-People ಮತ್ತು ಗುಂಪುಗಳು. ಈ ಪಾತ್ರಕ್ಕೆ ಮಾಡುವ ಬದಲಾವಣೆಗಳು ಹಿಂದಿನ ದಿನಾಂಕದಿಂದ ಅನ್ವಯಿಸುವುದಿಲ್ಲ. ವ್ಯವಸ್ಥೆಯಲ್ಲಿರುವ ಹಳೆಯ ಬಿಟ್‌ಸ್ಟ್ರೀಮ್‌ಗಳು ಅವುಗಳನ್ನು ಸೇರಿಸಿದ ಸಮಯದಲ್ಲಿ ಓದುವ ಪ್ರವೇಶ ಇದ್ದವರಿಂದ ಇನ್ನೂ ವೀಕ್ಷಿಸಬಹುದು.",

  "comcol-role.edit.bitstream_read.anonymous-group": "ಬರುವ ಬಿಟ್‌ಸ್ಟ್ರೀಮ್‌ಗಳಿಗಾಗಿ ಪೂರ್ವನಿಯೋಜಿತ ಓದು ಪ್ರಸ್ತುತ Anonymous ಗೆ ಹೊಂದಿಸಲಾಗಿದೆ.",

  "comcol-role.edit.editor.name": "ಸಂಪಾದಕರು",

  "comcol-role.edit.editor.description": "ಸಂಪಾದಕರು ಬರುವ ಸಲ್ಲಿಕೆಗಳ ಮೆಟಾಡೇಟಾವನ್ನು ಸಂಪಾದಿಸಿ, ನಂತರ ಅವನ್ನು ಅಂಗೀಕರಿಸಬಹುದು ಅಥವಾ ತಿರಸ್ಕರಿಸಬಹುದು.",

  "comcol-role.edit.finaleditor.name": "ಅಂತಿಮ ಸಂಪಾದಕರು",

  "comcol-role.edit.finaleditor.description": "ಅಂತಿಮ ಸಂಪಾದಕರು ಬರುವ ಸಲ್ಲಿಕೆಗಳ ಮೆಟಾಡೇಟಾವನ್ನು ಸಂಪಾದಿಸಬಹುದು, ಆದರೆ ಅವನ್ನು ತಿರಸ್ಕರಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ.",

  "comcol-role.edit.reviewer.name": "ವಿಮರ್ಶಕರು",

  "comcol-role.edit.reviewer.description": "ವಿಮರ್ಶಕರು ಬರುವ ಸಲ್ಲಿಕೆಗಳನ್ನು ಅಂಗೀಕರಿಸಬಹುದು ಅಥವಾ ತಿರಸ್ಕರಿಸಬಹುದು. ಆದರೆ, ಅವರು ಸಲ್ಲಿಕೆಯ ಮೆಟಾಡೇಟಾವನ್ನು ಸಂಪಾದಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ.",

  "comcol-role.edit.scorereviewers.name": "ಅಂಕ ನೀಡುವ ವಿಮರ್ಶಕರು",

  "comcol-role.edit.scorereviewers.description": "ವಿಮರ್ಶಕರು ಬರುವ ಸಲ್ಲಿಕೆಗಳಿಗೆ ಅಂಕ ನೀಡಬಹುದು; ಇದರ ಆಧಾರದ ಮೇಲೆ ಸಲ್ಲಿಕೆಯನ್ನು ತಿರಸ್ಕರಿಸಬೇಕೇ ಇಲ್ಲವೇ ಎಂಬುದು ನಿರ್ಧಾರವಾಗುತ್ತದೆ.",

