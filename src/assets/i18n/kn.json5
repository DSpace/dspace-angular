  "ldn-service.form.pattern.ack-accept.label": "ಸ್ವೀಕರಿಸಿ ಮತ್ತು ಅಂಗೀಕರಿಸಿ",

  "ldn-service.form.pattern.ack-accept.description": "ಈ ಮಾದರಿಯನ್ನು ಒಂದು ವಿನಂತಿ (ಆಫರ್) ಅನ್ನು ಅಂಗೀಕರಿಸಿ ಸ್ವೀಕರಿಸಲು ಬಳಸಲಾಗುತ್ತದೆ. ಇದು ಆ ವಿನಂತಿಯ ಮೇಲೆ ಕಾರ್ಯನಿರ್ವಹಿಸುವ ಉದ್ದೇಶವನ್ನು ಸೂಚಿಸುತ್ತದೆ.",

  "ldn-service.form.pattern.ack-accept.category": "ಅಂಗೀಕಾರಗಳು",

  "ldn-service.form.pattern.ack-reject.label": "ಅಂಗೀಕರಿಸಿ ಮತ್ತು ತಿರಸ್ಕರಿಸಿ",

  "ldn-service.form.pattern.ack-reject.description": "ಈ ಮಾದರಿಯನ್ನು ಒಂದು ವಿನಂತಿ (ಆಫರ್) ಅನ್ನು ಅಂಗೀಕರಿಸಿ ತಿರಸ್ಕರಿಸಲು ಬಳಸಲಾಗುತ್ತದೆ. ಇದು ಆ ವಿನಂತಿಗೆ ಸಂಬಂಧಿಸಿದಂತೆ ಮುಂದಿನ ಕ್ರಮವಿಲ್ಲ ಎಂಬುದನ್ನು ಸೂಚಿಸುತ್ತದೆ.",

  "ldn-service.form.pattern.ack-reject.category": "ಅಂಗೀಕಾರಗಳು",

  "ldn-service.form.pattern.ack-tentative-accept.label": "ಅಂಗೀಕರಿಸಿ ಮತ್ತು ತಾತ್ಕಾಲಿಕವಾಗಿ ಸ್ವೀಕರಿಸಿ",

  "ldn-service.form.pattern.ack-tentative-accept.description": "ಈ ಮಾದರಿಯನ್ನು ಒಂದು ವಿನಂತಿ (ಆಫರ್) ಅನ್ನು ಅಂಗೀಕರಿಸಿ ತಾತ್ಕಾಲಿಕವಾಗಿ ಸ್ವೀಕರಿಸಲು ಬಳಸಲಾಗುತ್ತದೆ. ಇದು ಕ್ರಮ ಕೈಗೊಳ್ಳುವ ಉದ್ದೇಶವನ್ನು ಸೂಚಿಸುತ್ತದೆ, ಆದರೆ ಅದು ಬದಲಾಗಬಹುದು.",

  "ldn-service.form.pattern.ack-tentative-accept.category": "ಅಂಗೀಕಾರಗಳು",

  "ldn-service.form.pattern.ack-tentative-reject.label": "ಅಂಗೀಕರಿಸಿ ಮತ್ತು ತಾತ್ಕಾಲಿಕವಾಗಿ ತಿರಸ್ಕರಿಸಿ",

  "ldn-service.form.pattern.ack-tentative-reject.description": "ಈ ಮಾದರಿಯನ್ನು ಒಂದು ವಿನಂತಿ (ಆಫರ್) ಅನ್ನು ಅಂಗೀಕರಿಸಿ ತಾತ್ಕಾಲಿಕವಾಗಿ ತಿರಸ್ಕರಿಸಲು ಬಳಸಲಾಗುತ್ತದೆ. ಇದು ಮುಂದಿನ ಕ್ರಮವಿಲ್ಲ ಎಂಬುದನ್ನು, ಆದರೆ ಅದು ಬದಲಾಗಬಹುದು ಎಂಬ ಷರತ್ತಿನೊಂದಿಗೆ ಸೂಚಿಸುತ್ತದೆ.",

  "ldn-service.form.pattern.ack-tentative-reject.category": "ಅಂಗೀಕಾರಗಳು",

