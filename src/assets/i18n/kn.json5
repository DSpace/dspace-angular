  "info.accessibility-settings.breadcrumbs": "ಪ್ರವೇಶಾರ್ಹತಾ ಸಂಯೋಜನೆಗಳು",

  "info.accessibility-settings.cookie-warning": "ಪ್ರವೇಶಾರ್ಹತಾ ಸಂಯೋಜನೆಗಳನ್ನು ಉಳಿಸುವುದು ಪ್ರಸ್ತುತ ಸಾಧ್ಯವಿಲ್ಲ. ಸಂಯೋಜನೆಗಳನ್ನು ಬಳಕೆದಾರ ಡೇಟಾದಲ್ಲಿ ಉಳಿಸಲು ಲಾಗಿನ್ ಆಗಿ, ಅಥವಾ ಪುಟದ ಕೆಳಭಾಗದಲ್ಲಿರುವ 'Cookie Settings' ಮೆನು ಮೂಲಕ 'Accessibility Settings' ಕುಕಿಯನ್ನು ಸ್ವೀಕರಿಸಿ. ಕುಕಿ ಸ್ವೀಕರಿಸಿದ ನಂತರ, ಈ ಸಂದೇಶವನ್ನು ತೆಗೆದುಹಾಕಲು ಪುಟವನ್ನು ಮರುಲೋಡ್ ಮಾಡಬಹುದು.",

  "info.accessibility-settings.disableNotificationTimeOut.label": "ಟೈಮ್‌ಔಟ್ ನಂತರ ಅಧಿಸೂಚನೆಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಮುಚ್ಚಿ",

  "info.accessibility-settings.disableNotificationTimeOut.hint": "ಈ ಟಾಗಲ್ ಸಕ್ರಿಯವಾದಾಗ, ಟೈಮ್‌ಔಟ್ ನಂತರ ಅಧಿಸೂಚನೆಗಳು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಮುಚ್ಚುತ್ತವೆ. ನಿಷ್ಕ್ರಿಯವಾದಾಗ, ಅವು ಕೈಯಾರೆ ಮುಚ್ಚುವವರೆಗೂ ತೆರೆದಿರುತ್ತವೆ.",

  "info.accessibility-settings.failed-notification": "ಪ್ರವೇಶಾರ್ಹತಾ ಸಂಯೋಜನೆಗಳನ್ನು ಉಳಿಸಲು ವಿಫಲವಾಯಿತು",

  "info.accessibility-settings.invalid-form-notification": "ಉಳಿಸಲಾಗಲಿಲ್ಲ. ಫಾರ್ಮ್‌ನಲ್ಲಿ ಅಮಾನ್ಯ ಮೌಲ್ಯಗಳಿವೆ.",

  "info.accessibility-settings.liveRegionTimeOut.label": "ARIA Live region ಟೈಮ್‌ಔಟ್ (ಸೆಕೆಂಡುಗಳಲ್ಲಿ)",

  "info.accessibility-settings.liveRegionTimeOut.hint": "ARIA live region ನಲ್ಲಿ ಸಂದೇಶ ಕಳೆದುಹೋಗುವ ಅವಧಿ. ARIA live regions ಪುಟದಲ್ಲಿ ಕಾಣಿಸುವುದಿಲ್ಲ, ಆದರೆ ಸ್ಕ್ರೀನ್ ರೀಡರ್‌ಗಳಿಗೆ ಅಧಿಸೂಚನೆಗಳ ಅಥವಾ ಇತರ ಕ್ರಿಯೆಗಳ ಘೋಷಣೆಗಳನ್ನು ಒದಗಿಸುತ್ತವೆ.",

