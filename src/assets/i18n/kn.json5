  "grant-deny-request-copy.email.back": "ಹಿಂದೆ",

  "grant-deny-request-copy.email.message": "ಐಚ್ಛಿಕ ಹೆಚ್ಚುವರಿ ಸಂದೇಶ",

  "grant-deny-request-copy.email.message.empty": "ದಯವಿಟ್ಟು ಒಂದು ಸಂದೇಶವನ್ನು ನಮೂದಿಸಿ",

  "grant-deny-request-copy.email.permissions.info": "ಈ ಸಂದರ್ಭವನ್ನು ಬಳಸಿಕೊಂಡು ದಸ್ತಾವೇಜಿನ ಪ್ರವೇಶ ನಿರ್ಬಂಧಗಳನ್ನು ಮರುಪರಿಶೀಲಿಸಬಹುದು, ಇದರಿಂದ ಇಂತಹ ವಿನಂತಿಗಳಿಗೆ ಉತ್ತರಿಸುವ ಅಗತ್ಯ ಕಡಿಮೆಯಾಗುತ್ತದೆ. ಈ ನಿರ್ಬಂಧಗಳನ್ನು ತೆಗೆದುಹಾಕಲು ಸಂಗ್ರಹಣಾ ನಿರ್ವಾಹಕರನ್ನು ಕೇಳಲು ಬಯಸಿದರೆ, ಕೆಳಗಿನ ಬಾಕ್ಸ್ ಅನ್ನು ಗುರುತಿಸಿ.",

  "grant-deny-request-copy.email.permissions.label": "ತೆರೆದ ಪ್ರವೇಶಕ್ಕೆ ಬದಲಾವಣೆ",

  "grant-deny-request-copy.email.send": "ಕಳುಹಿಸಿ",

  "grant-deny-request-copy.email.subject": "ವಿಷಯ",

  "grant-deny-request-copy.email.subject.empty": "ದಯವಿಟ್ಟು ಒಂದು ವಿಷಯವನ್ನು ನಮೂದಿಸಿ",

  "grant-deny-request-copy.grant": "ಪ್ರವೇಶ ವಿನಂತಿಯನ್ನು ಅನುಮತಿಸಿ",

  "grant-deny-request-copy.header": "ದಸ್ತಾವೇಜಿನ ಪ್ರತಿಯ ವಿನಂತಿ",

  "grant-deny-request-copy.home-page": "ನನ್ನನ್ನು ಮುಖಪುಟಕ್ಕೆ ಕರೆದೊಯ್ಯಿ",

  "grant-deny-request-copy.intro1": "ನೀವು ದಸ್ತಾವೇಜು <a href='{{ url }}'>{{ name }}</a> ನ ಲೇಖಕರಲ್ಲಿ ಒಬ್ಬರಾಗಿದ್ದರೆ, ಬಳಕೆದಾರರ ವಿನಂತಿಗೆ ಪ್ರತಿಕ್ರಿಯಿಸಲು ಕೆಳಗಿನ ಆಯ್ಕೆಗಳಲ್ಲಿ ಒಂದನ್ನು ಬಳಸಿ.",

  "grant-deny-request-copy.intro2": "ಆಯ್ಕೆಯನ್ನು ಆರಿಸಿದ ನಂತರ, ನಿಮಗೆ ಸೂಚಿಸಲಾದ ಇಮೇಲ್ ಪ್ರತಿಕ್ರಿಯೆ ತೋರಿಸಲಾಗುತ್ತದೆ; ಅದನ್ನು ನೀವು ಸಂಪಾದಿಸಬಹುದು.",

  "grant-deny-request-copy.previous-decision": "ಈ ವಿನಂತಿಯನ್ನು ಹಿಂದೆ ಸುರಕ್ಷಿತ ಪ್ರವೇಶ ಟೋಕನ್‌ನೊಂದಿಗೆ ಅನುಮತಿಸಲಾಗಿತ್ತು. ಈ ಪ್ರವೇಶವನ್ನು ಈಗಲೇ ಹಿಂಪಡೆದು ಆ ಟೋಕನ್ ಅನ್ನು ತಕ್ಷಣ ಅಮಾನ್ಯಗೊಳಿಸಬಹುದು",

  "grant-deny-request-copy.processed": "ಈ ವಿನಂತಿ ಈಗಾಗಲೇ ಪ್ರಕ್ರಿಯೆಯಾಗಿದೆ. ಮುಖಪುಟಕ್ಕೆ ಮರಳಲು ಕೆಳಗಿನ ಬಟನ್ ಬಳಸಬಹುದು.",

  "grant-request-copy.email.subject": "ದಸ್ತಾವೇಜಿನ ಪ್ರತಿಗಾಗಿ ವಿನಂತಿ",

  "grant-request-copy.error": "ದೋಷ ಉಂಟಾಯಿತು",

  "grant-request-copy.header": "ದಸ್ತಾವೇಜಿನ ಪ್ರತಿಯ ವಿನಂತಿಯನ್ನು ಅನುಮತಿಸಿ",

  "grant-request-copy.intro.attachment": "ವಿನಂತಿಯ ಅರ್ಜಿದಾರರಿಗೆ ಸಂದೇಶ ಕಳುಹಿಸಲಾಗುತ್ತದೆ. ವಿನಂತಿಸಿದ ದಸ್ತಾವೇಜು(ಗಳು) ಅನ್ನು ಲಗತ್ತಿಸಲಾಗುತ್ತದೆ.",

  "grant-request-copy.intro.link": "ವಿನಂತಿಯ ಅರ್ಜಿದಾರರಿಗೆ ಸಂದೇಶ ಕಳುಹಿಸಲಾಗುತ್ತದೆ. ವಿನಂತಿಸಿದ ದಸ್ತಾವೇಜು(ಗಳು)ಗೆ ಪ್ರವೇಶ ನೀಡುವ ಸುರಕ್ಷಿತ ಲಿಂಕ್ ಅನ್ನು ಲಗತ್ತಿಸಲಾಗುತ್ತದೆ. ಕೆಳಗಿನ \"ಪ್ರವೇಶ ಅವಧಿ\" ಮೆನುವಿನಲ್ಲಿ ಆಯ್ಕೆಮಾಡಿದ ಅವಧಿಗೆ ಲಿಂಕ್ ಪ್ರವೇಶ ನೀಡುತ್ತದೆ.",

