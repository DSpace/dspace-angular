  "external-login.component.or": "ಅಥವಾ",

  "external-login.confirmation.header": "ಲಾಗಿನ್ ಪ್ರಕ್ರಿಯೆ ಪೂರ್ಣಗೊಳಿಸಲು ಅಗತ್ಯವಿರುವ ಮಾಹಿತಿ",

  "external-login.noEmail.informationText": "{{authMethod}} ನಿಂದ ಬಂದ ಮಾಹಿತಿ ಲಾಗಿನ್ ಪ್ರಕ್ರಿಯೆ ಪೂರ್ಣಗೊಳಿಸಲು ಸಾಕಾಗಿಲ್ಲ. ದಯವಿಟ್ಟು ಕೆಳಗಿನ ಕಾಣೆಯಾದ ಮಾಹಿತಿಯನ್ನು ಒದಗಿಸಿ, ಅಥವಾ ನಿಮ್ಮ {{authMethod}} ಅನ್ನು ಅಸ್ತಿತ್ವದಲ್ಲಿರುವ ಖಾತೆಗೆ ಸಂಪರ್ಕಿಸಲು ಬೇರೆ ವಿಧಾನದಿಂದ ಲಾಗಿನ್ ಮಾಡಿ",

  "external-login.haveEmail.informationText": "ನಿಮಗೆ ಈ ವ್ಯವಸ್ಥೆಯಲ್ಲಿ ಇನ್ನೂ ಖಾತೆ ಇಲ್ಲವೆಂದು ತೋರುತ್ತದೆ. ಹಾಗಿದ್ದರೆ, ದಯವಿಟ್ಟು {{authMethod}} ನಿಂದ ಬಂದ ಡೇಟಾವನ್ನು ದೃಢೀಕರಿಸಿ, ನಿಮಗಾಗಿ ಹೊಸ ಖಾತೆ ರಚಿಸಲಾಗುತ್ತದೆ. ಇಲ್ಲವೇ, ನಿಮಗೆ ಈಗಾಗಲೇ ಖಾತೆ ಇದ್ದರೆ, ಇಮೇಲ್ ವಿಳಾಸವನ್ನು ವ್ಯವಸ್ಥೆಯಲ್ಲಿ ಈಗಾಗಲೇ ಬಳಕೆಯಲ್ಲಿರುವದ್ದಕ್ಕೆ ಹೊಂದಿಸಿ ಅಥವಾ ಬೇರೆ ವಿಧಾನದಿಂದ ಲಾಗಿನ್ ಮಾಡಿ, ನಿಮ್ಮ {{authMethod}} ಅನ್ನು ಅಸ್ತಿತ್ವದಲ್ಲಿರುವ ಖಾತೆಗೆ ಸಂಪರ್ಕಿಸಿ",

  "external-login.confirm-email.header": "ಇಮೇಲ್ ದೃಢೀಕರಿಸಿ ಅಥವಾ ನವೀಕರಿಸಿ",

  "external-login.confirmation.email-required": "ಇಮೇಲ್ ಅಗತ್ಯವಿದೆ.",

