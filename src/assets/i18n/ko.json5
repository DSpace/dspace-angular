  "external-login.component.or": "वा",

  "external-login.confirmation.header": "लॉगिन प्रक्रिया पुराय करपाखातीर गरजेची म्हायती",

  "external-login.noEmail.informationText": "{{authMethod}} थावन मेळिल्ली म्हायती लॉगिन प्रक्रिया पुराय करपाखातीर पुरेशी ना. कृपया खालच्याभागांत उणी म्हायती दियात, वा तुमच्या {{authMethod}} क आदूच्या account वांगडा जोडपाखातीर वेगळ्या पद्धतीन लॉगिन करात.",

  "external-login.haveEmail.informationText": "असें दिसता की तुमच्या कडेन अजून ह्या system मदीं account ना. जर हें खरें आसलें, तर कृपया {{authMethod}} थावन मेळिल्ल्या डेटाची खात्री करात आनी तुमच्या खातीर नवें account तयार जातलें. न्हय जाल्यार, जर तुमच्या कडेन आदूच system मदीं account आसा, तर e-mail पत्तो अद्ययावत करून तो system मदीं वापरात आसिल्ल्या पत्त्याशीं जुळोवात वा तुमच्या {{authMethod}} क तुमच्या विद्यमान account वांगडा जोडपाखातीर वेगळ्या पद्धतीन लॉगिन करात.",

  "external-login.confirm-email.header": "ईमेल खात्री करात वा अद्ययावत करात",

  "external-login.confirmation.email-required": "ईमेल गरजेचो आसा.",

