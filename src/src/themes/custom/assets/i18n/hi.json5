  'about.contact.email.title': 'ईमेल',
  'about.contact.email.address': 'lgarchciil[at]gmail[dot]com',
  'contrib.badge': 'श्रेय',
  'contrib.title.html': 'योगदानकर्ता <span>पृष्ठ</span>',
  'contrib.section.initiative': 'पहल के बारे में',
  'contrib.intro.p1': '<strong>भाषा संचिका</strong>, भारतीय भाषा संस्थान (CIIL) का डिजिटल भाषा भंडार, भारतीय भाषाओं को संरक्षित करने के लिए समर्पित सामूहिक प्रयासों के एक प्रमाण के रूप में खड़ा है। 56 वर्ष से अधिक समय पहले स्थापित, CIIL अपने इस मिशन में विविध हितधारकों को सक्रिय रूप से शामिल करता है। सहयोग इसकी मुख्य धुरी है, जो सरकारी पहलों, शैक्षणिक संस्थानों, तकनीकी नवाचारों और जमीनी स्तर पर सामुदायिक भागीदारी को एक साथ पिरोता है।',
  'contrib.intro.p2': 'यह सहयोगात्मक दृष्टिकोण भारत में भाषाई विविधता के जटिल परिदृश्य को दिशा देने में अत्यंत महत्वपूर्ण है, जो यह सुनिश्चित करता है कि यह भंडार भाषा संरक्षण, प्रसार और तकनीकी प्रगति के लिए एक साझा संसाधन बने। हम इस अवसर पर उन सभी योगदानों के प्रति आभार व्यक्त करते हैं जिन्होंने भाषा संचिका को एक वास्तविकता बनाया है।',
  'contrib.section.leadership': 'हमारा नेतृत्व',
