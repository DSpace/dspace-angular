  'about.contact.address.title': 'आधिकारिक पता',
  'about.contact.address.text': 'भारतीय भाषा संस्थान<br>उच्च शिक्षा विभाग<br>शिक्षा मंत्रालय, भारत सरकार<br>मैसूरु – 570006',
  'about.contact.person.title': 'संपर्क व्यक्ति',
